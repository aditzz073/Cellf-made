# backend/.env.example
# Copy this file to .env and adjust for your environment.

# Comma-separated list of allowed CORS origins.
# Add your production frontend URL here when deploying.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database - SQLite for dev; swap for postgresql://user:pass@host/db in prod
DATABASE_URL=sqlite:///./sepsisai.db

# JWT - MUST be changed to a long random secret in production
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=1440
